# Resend — automated contact-form email.
# 1. Create an account at https://resend.com and generate an API key.
# 2. Copy this file to `.env.local` and paste your real key below.
# 3. (Optional) After verifying your domain in Resend, set CONTACT_FROM_EMAIL
#    to an address on that domain, e.g. "VantixGrowth <hello@vantixgrowth.com>".
#    Until then, leave it unset to use Resend's shared test sender.

RESEND_API_KEY=re_your_api_key_here
# CONTACT_FROM_EMAIL=VantixGrowth <onboarding@resend.dev>
